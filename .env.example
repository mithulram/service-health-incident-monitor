# Copy to .env and customize before `docker compose up`.
# Never commit .env with real secrets.

# Required for protected admin routes when DEMO_MODE=false
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Production-safe defaults for self-host
DEMO_MODE=false
SCHEDULER_ENABLED=true
ALERTS_ENABLED=false

# Persist SQLite data in ./data (Docker volume mount)
DATABASE_URL=sqlite:////app/data/service_monitor.db

# Companion frontend origin(s) for browser API access
WEB_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional link in alert emails and status-page references
FRONTEND_PUBLIC_URL=http://localhost:5173/status/default

# Optional email alerts (keep ALERTS_ENABLED=false until SMTP is configured)
# ALERT_SEND_RESOLVED=true
# ALERT_EMAIL_TO=ops@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=monitor@example.com

# Optional tuning
# CHECK_TIMEOUT_SECONDS=5
# MAX_MONITORS=25
# MAX_CONCURRENT_CHECKS=10
# DATA_RETENTION_DAYS=7
